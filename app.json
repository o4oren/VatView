
{
  "expo": {
    "name": "VatView",
    "slug": "vatview",
    "version": "1.9.1",
    "orientation": "portrait",
    "icon": "./graphics/icons/icon-1024-background.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "androidStatusBar": {
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gevahim.vatview",
      "buildNumber": "1.9.1",
      "config": {
        "googleMapsApiKey": "AIzaSyBgzIoWm3eIB5mEvOqFAdIGdLC_6IRFeLk"
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.gevahim.vatview",
      "versionCode": 191,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBgzIoWm3eIB5mEvOqFAdIGdLC_6IRFeLk"
        }
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "com.google.android.gms.permission.AD_ID"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "config": {
        "firebase": {
          "apiKey": "[REPLACE]",
          "measurementId": "G-C7CHC7DF09"
        }
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "description": "VatView is a VATSIM map and information app.",
    "githubUrl": "https://github.com/o4oren/VatView",
    "extra": {
      "eas": {
        "projectId": "700dac5e-72d8-45e4-8bf5-693f1bb78b70"
      }
    },
    "owner": "ogeva"
  }
}
