# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and will never be committed.

# Google Maps API key — required for the map to render on both platforms.
# Create a key at https://console.cloud.google.com and enable the Maps SDK
# for Android and Maps SDK for iOS.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
